/* ============================================
   Cherry Studio 风格 — 浅色版 (Light Mode)
   认知增强系统 v3 全局样式
   ============================================ */

/* 全局基础 */
QWidget {
    background-color: #f5f7fa;
    color: #333333;
    font-family: "Microsoft YaHei UI", "Segoe UI", "PingFang SC", sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #f5f7fa;
}

/* ═══════════ 左侧 Sidebar ═══════════ */

QFrame#sidebar {
    background-color: #ffffff;
    border-right: 1px solid #e8eaed;
}

QFrame#sidebarItem {
    background-color: transparent;
    border-radius: 8px;
    padding: 4px;
}

QFrame#sidebarItem:hover {
    background-color: #f0f2f5;
}

QFrame#sidebarItemSelected {
    background-color: #e6f0fa;
    border-radius: 8px;
    padding: 4px;
}

QLabel#sidebarLabel {
    color: #333333;
    background-color: transparent;
    border: none;
    font-size: 13px;
}

QLabel#sidebarLabelSelected {
    color: #5A9EBF;
    background-color: transparent;
    border: none;
    font-size: 13px;
    font-weight: 500;
}

QLabel#sidebarLabelInactive {
    color: #888888;
    background-color: transparent;
    border: none;
    font-size: 13px;
}

/* ═══════════ Tab 标签栏（兼容旧布局）═══════════ */

QTabWidget::pane {
    border: none;
    background-color: #f5f7fa;
    top: -1px;
}

QTabBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e0e0e0;
}

QTabBar::tab {
    background-color: transparent;
    color: #666666;
    padding: 10px 20px;
    margin-right: 2px;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 13px;
    font-weight: 500;
}

QTabBar::tab:hover {
    color: #333333;
    background-color: #f0f2f5;
}

QTabBar::tab:selected {
    color: #5A9EBF;
    border-bottom: 2px solid #5A9EBF;
    background-color: #f5f7fa;
}

/* ═══════════ 按钮 ═══════════ */

QPushButton {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    min-height: 32px;
}

QPushButton:hover {
    background-color: #f0f2f5;
    border-color: #bfbfbf;
}

QPushButton:pressed {
    background-color: #e6e8eb;
}

QPushButton:disabled {
    background-color: #f5f5f5;
    color: #999999;
    border-color: #e0e0e0;
}

QPushButton#primaryBtn {
    background-color: #5A9EBF;
    color: #ffffff;
    border: 1px solid #5A9EBF;
    font-weight: 500;
}

QPushButton#primaryBtn:hover {
    background-color: #6bb0d1;
    border-color: #6bb0d1;
}

QPushButton#primaryBtn:pressed {
    background-color: #4a8eaf;
}

QPushButton#dangerBtn {
    background-color: #ff4d4f;
    color: #ffffff;
    border: 1px solid #ff4d4f;
}

QPushButton#dangerBtn:hover {
    background-color: #ff7875;
}

/* ═══════════ 表格 ══════════ */

QTableView {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    gridline-color: #f0f0f0;
    selection-background-color: #e6f7ff;
    selection-color: #333333;
}

QTableView::item {
    padding: 8px 12px;
    border-bottom: 1px solid #f5f5f5;
}

QTableView::item:hover {
    background-color: #fafafa;
}

QTableView::item:selected {
    background-color: #e6f7ff;
    color: #333333;
}

QHeaderView::section {
    background-color: #fafafa;
    color: #666666;
    padding: 10px 12px;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    font-weight: 600;
    font-size: 12px;
}

/* ═══════════ 滚动条 ═══════════ */

QScrollBar:vertical {
    background-color: #f5f7fa;
    width: 8px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background-color: #d9d9d9;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #bfbfbf;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #f5f7fa;
    height: 8px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal {
    background-color: #d9d9d9;
    border-radius: 4px;
    min-width: 30px;
}

/* ═══════════ 输入框 ═══════════ */

QLineEdit, QTextEdit {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    padding: 8px 12px;
    color: #333333;
    selection-background-color: #5A9EBF;
    selection-color: #ffffff;
}

QLineEdit:focus, QTextEdit:focus {
    border-color: #5A9EBF;
    background-color: #ffffff;
}

QLineEdit::placeholder {
    color: #999999;
}

QTextEdit {
    border-radius: 8px;
}

/* ═══════════ 下拉框 ═══════════ */

QComboBox {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    padding: 6px 12px;
    color: #333333;
}

QComboBox:hover {
    border-color: #bfbfbf;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    selection-background-color: #e6f7ff;
    selection-color: #333333;
}

/* ═══════════ 终端日志面板 ═══════════ */

QPlainTextEdit#terminalLog {
    background-color: #1e1e1e;
    color: #d4d4d4;
    font-family: "Cascadia Code", "Consolas", "Courier New", monospace;
    font-size: 12px;
    border: none;
    border-radius: 0;
    padding: 8px;
}

/* ═══════════ 状态栏 ═══════════ */

QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #e0e0e0;
    color: #666666;
    font-size: 12px;
}

/* ═══════════ 标签 ═══════════ */

QLabel {
    color: #333333;
}

QLabel#titleLabel {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
}

QLabel#subtitleLabel {
    font-size: 12px;
    color: #888888;
}

/* ═══════════ 卡片容器 ═══════════ */

QFrame#cardFrame {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 12px;
}

/* ═══════════ 分隔线 ═══════════ */

QFrame#separator {
    background-color: #e0e0e0;
    max-height: 1px;
}

/* ══════════ 搜索框 ═══════════ */

QLineEdit#searchBox {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 20px;
    padding: 8px 16px;
    color: #333333;
}

QLineEdit#searchBox:focus {
    border-color: #5A9EBF;
    background-color: #ffffff;
}

/* ═══════════ 气泡消息（聊天窗）═══════════ */

QFrame#userBubble {
    background-color: #5A9EBF;
    color: #ffffff;
    border-radius: 12px;
    padding: 10px 14px;
    margin: 4px 0;
}

QFrame#agentBubble {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 10px 14px;
    margin: 4px 0;
}

/* ═══════════ 优先级标签 ═══════════ */

QLabel#priorityP1 { color: #e74c3c; font-weight: 600; }
QLabel#priorityP2 { color: #f39c12; font-weight: 600; }
QLabel#priorityP3 { color: #3498db; font-weight: 600; }
QLabel#priorityP4 { color: #9b59b6; font-weight: 600; }
QLabel#priorityP5 { color: #2ecc71; font-weight: 600; }

/* ═══════════ 状态标签 ═══════════ */

QLabel#statusCompleted { color: #2ecc71; }
QLabel#statusPending { color: #f39c12; }
QLabel#statusInProgress { color: #3498db; }

/* ═══════════ 聊天区（浅色适配）═══════════ */

QScrollArea {
    border: none;
    background: #f5f7fa;
}

QFrame#chatTopBar {
    background: #ffffff;
    border-bottom: 1px solid #e8eaed;
}

QFrame#chatInputBar {
    background: #ffffff;
    border-top: 1px solid #e8eaed;
}

QFrame#emotionalStatusBar {
    background: #e8f0fe;
    border-top: 1px solid #d4e0f0;
}

/* ═══════════ 热力图/甘特图 ═══════════ */

QFrame#heatmapContainer {
    background-color: #ffffff;
    border-radius: 8px;
}

QFrame#ganttContainer {
    background-color: #ffffff;
    border-radius: 8px;
}

/* ═══════════ 分割线 ═══════════ */

QSplitter::handle {
    background-color: #e0e0e0;
}

QSplitter::handle:horizontal {
    width: 1px;
}

QSplitter::handle:vertical {
    height: 1px;
}

/* ═══════════ Dock Widget ═══════════ */

QDockWidget {
    background-color: #f5f7fa;
    color: #333333;
}

QDockWidget::title {
    background-color: #ffffff;
    border-bottom: 1px solid #e0e0e0;
    padding: 6px 8px;
    font-weight: 500;
    font-size: 12px;
    color: #666666;
}
